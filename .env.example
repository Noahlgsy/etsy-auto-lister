# Etsy Open API v3 credentials — récupérés sur https://www.etsy.com/developers/your_apps
ETSY_KEYSTRING=
ETSY_SHARED_SECRET=

# Rempli automatiquement après `python -m src.auth` (ne pas toucher à la main)
ETSY_REFRESH_TOKEN=
ETSY_USER_ID=
ETSY_SHOP_ID=

# Clé API Anthropic pour générer titres/descriptions et analyser les photos
# À récupérer sur https://console.anthropic.com/
ANTHROPIC_API_KEY=

# URL de ton API eRank scraper locale (par défaut http://127.0.0.1:8765)
# Lance-la avec `python api.py` dans le dossier erank-tag-searcher-competition-fix
ERANK_API_URL=http://127.0.0.1:8765
# Token X-API-Key uniquement si tu as démarré l'API avec --auth-token
ERANK_API_TOKEN=
